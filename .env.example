# ══════════════════════════════════════════════
# LUXO REBORN — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# NUNCA commite o .env.local no GitHub
# ══════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────────
# Pegue em: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── MERCADO PAGO ────────────────────────────────
# Pegue em: https://www.mercadopago.com.br/developers
# Use credenciais de PRODUÇÃO (não teste) em produção
MERCADOPAGO_ACCESS_TOKEN=APP_USR-seu_access_token_aqui
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-sua_public_key_aqui

# ── APP ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção: NEXT_PUBLIC_APP_URL=https://luxoreborn.com.br

# ── ANALYTICS (opcional, recomendado para conversão) ─────
# Google Analytics 4 (ex: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Meta Pixel (ex: 123456789012345)
NEXT_PUBLIC_META_PIXEL_ID=

# ── ADMIN ───────────────────────────────────────
# Senha simples para proteger o painel admin (mude para algo seguro)
ADMIN_SECRET_KEY=mude_esta_senha_para_algo_seguro_123
# Secret para assinar sessão da área do cliente (recomendado diferente do admin)
CUSTOMER_AUTH_SECRET=mude_esta_chave_para_algo_longo_e_seguro

# ── WEBHOOK ─────────────────────────────────────
# Secret para validar webhooks do Mercado Pago (OBRIGATÓRIO em produção)
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# ── FRETE (Melhor Envio) ─────────────────────────
# Opcional: quando informado, o checkout calcula frete via Melhor Envio.
MELHOR_ENVIO_ACCESS_TOKEN=
MELHOR_ENVIO_FROM_POSTAL_CODE=01001000
# Opcional (default: https://www.melhorenvio.com.br)
MELHOR_ENVIO_BASE_URL=
# IDs de serviços separados por vírgula (ex: 1,2)
MELHOR_ENVIO_SERVICES=1,2
# Dimensões padrão para cotação (cm)
MELHOR_ENVIO_DEFAULT_WIDTH_CM=16
MELHOR_ENVIO_DEFAULT_HEIGHT_CM=6
MELHOR_ENVIO_DEFAULT_LENGTH_CM=22

# ── RASTREAMENTO AUTOMÁTICO (CRON) ──────────────
# Token Bearer usado no endpoint /api/cron/tracking-sync
TRACKING_SYNC_SECRET=
